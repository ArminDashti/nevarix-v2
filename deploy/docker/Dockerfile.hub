FROM golang:1.23-bookworm AS builder
WORKDIR /src
COPY apps/hub/go.mod apps/hub/go.sum* ./apps/hub/
COPY apps/hub ./apps/hub
WORKDIR /src/apps/hub
RUN go mod download && CGO_ENABLED=0 go build -o /nvx-hub ./cmd/nvx-hub

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y ca-certificates && rm -rf /var/lib/apt/lists/*
COPY --from=builder /nvx-hub /usr/local/bin/nvx-hub
COPY configs/hub.yaml /etc/nvx/hub.yaml
EXPOSE 9443
CMD ["nvx-hub", "serve"]
